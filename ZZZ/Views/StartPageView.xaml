<UserControl x:Class="ZZZ.Views.StartPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">
    <Grid x:Name="Root">
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" IsHitTestVisible="False"/>
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28" MaxWidth="820">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Border Background="#D9202733" BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="15" Padding="2">
                <TextBox x:Name="SearchBox" Height="54" MinWidth="420" MaxWidth="700" Padding="18,0" FontSize="17"
                         VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" Foreground="White"
                         CaretBrush="White" KeyDown="SearchBox_KeyDown" ToolTip="{DynamicResource AddressPlaceholder}"/>
            </Border>
            <ItemsControl x:Name="BookmarksList" Grid.Row="1" Margin="0,18,0,0" HorizontalAlignment="Center">
                <ItemsControl.ItemTemplate><DataTemplate>
                    <StackPanel Margin="0,0,0,9">
                        <TextBlock Text="{Binding Name}" Foreground="White" Opacity="0.72" FontWeight="SemiBold" Margin="5,0,5,3"/>
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Center"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Button Tag="{Binding Url}" Click="Bookmark_Click" ToolTip="{Binding Url}" Margin="5" Padding="{Binding TilePadding}" Width="{Binding TileWidth}" Height="{Binding TileHeight}"
                                        Background="#C9202733" Foreground="White" BorderBrush="#44FFFFFF" BorderThickness="1">
                                    <StackPanel><TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" FontSize="{Binding TitleSize}" HorizontalAlignment="Center"/><TextBlock Text="{Binding DisplayUrl}" Visibility="{Binding ShowUrl, Converter={StaticResource BoolVisibility}}" Opacity="0.65" FontSize="10" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" Margin="0,4,0,0"/></StackPanel>
                                </Button>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate></ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
