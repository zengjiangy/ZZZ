<Window x:Class="ZZZ.Views.ClearDataWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Style="{StaticResource AppWindowStyle}"
        Title="{DynamicResource ClearDataTitle}" Height="390" Width="440" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="24" Background="{DynamicResource WindowBrush}"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,18"><Border Width="42" Height="42" CornerRadius="13" Background="{DynamicResource AccentSoftBrush}" Margin="0,0,13,0"><Viewbox Margin="10"><Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.8" Data="M4,6 L16,6 M7,6 L8,18 L14,18 L15,6 M8,3 L14,3 L15,6"/></Viewbox></Border><StackPanel><TextBlock Text="{DynamicResource ClearDataTitle}" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="{DynamicResource ClearDataSubtitle}" Foreground="{DynamicResource MutedBrush}"/></StackPanel></StackPanel>
        <StackPanel x:Name="SelectionPanel" Grid.Row="1">
            <TextBlock Text="{DynamicResource ChooseClear}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <CheckBox x:Name="HistoryCheck" Content="{DynamicResource History}" IsChecked="{Binding History}"/><CheckBox x:Name="CacheCheck" Content="{DynamicResource Cache}" IsChecked="{Binding Cache}"/>
            <CheckBox x:Name="CookiesCheck" Content="{DynamicResource Cookies}" IsChecked="{Binding Cookies}"/><CheckBox x:Name="PasswordsCheck" Content="{DynamicResource SavedPasswords}" IsChecked="{Binding Passwords}"/>
            <CheckBox x:Name="FormDataCheck" Content="{DynamicResource AutofillData}" IsChecked="{Binding FormData}"/>
        </StackPanel>
        <Border x:Name="ConfirmPanel" Grid.Row="1" Visibility="Collapsed" Background="{DynamicResource AddressBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="12" Padding="18" VerticalAlignment="Center"><StackPanel><TextBlock Text="{DynamicResource ConfirmClearTitle}" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="{DynamicResource ClearDataFinalConfirm}" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,0"/></StackPanel></Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="CancelButton" Content="{DynamicResource Cancel}" Click="Cancel_Click" Margin="0,0,8,0"/><Button x:Name="ClearButton" Content="{DynamicResource Continue}" Click="Clear_Click" Style="{StaticResource PrimaryButton}"/></StackPanel>
    </Grid>
</Window>
