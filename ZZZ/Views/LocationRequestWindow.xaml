<Window x:Class="ZZZ.Views.LocationRequestWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}" Title="{DynamicResource LocationRequest}" Width="470" Height="410" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Background="{DynamicResource WindowBrush}" Padding="24">
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal">
                <Border Width="42" Height="42" CornerRadius="13" Background="{DynamicResource AccentSoftBrush}" Margin="0,0,13,0">
                    <Viewbox Margin="10"><Path Fill="{DynamicResource AccentBrush}" Data="M10,1 C5.6,1 2,4.5 2,9 C2,15 10,23 10,23 C10,23 18,15 18,9 C18,4.5 14.4,1 10,1 M10,5 A4,4 0 1 1 10,13 A4,4 0 1 1 10,5"/></Viewbox>
                </Border>
                <StackPanel><TextBlock Text="{DynamicResource LocationRequest}" FontSize="20" FontWeight="SemiBold"/><TextBlock x:Name="SiteText" Foreground="{DynamicResource MutedBrush}" MaxWidth="350" TextTrimming="CharacterEllipsis"/></StackPanel>
            </StackPanel>
            <Border Grid.Row="1" Margin="0,18,0,12" Padding="12" CornerRadius="10" Background="{DynamicResource AccentSoftBrush}"><TextBlock Text="{DynamicResource LocationPrivacyHint}" TextWrapping="Wrap"/></Border>
            <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="{DynamicResource Latitude}" FontWeight="SemiBold"/><TextBlock Grid.Column="2" Text="{DynamicResource Longitude}" FontWeight="SemiBold"/>
                <TextBox x:Name="LatitudeBox" Grid.Row="1"/><TextBox x:Name="LongitudeBox" Grid.Row="1" Grid.Column="2"/>
                <TextBlock Grid.Row="2" Text="{DynamicResource AccuracyMeters}" FontWeight="SemiBold" Margin="0,12,0,0"/>
                <TextBox x:Name="AccuracyBox" Grid.Row="3" Grid.ColumnSpan="3"/>
            </Grid>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="{DynamicResource Deny}" Click="Deny_Click" Margin="0,0,8,0"/>
                <Button Content="{DynamicResource ReturnCustomLocation}" Click="Allow_Click" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
