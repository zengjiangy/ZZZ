<Window x:Class="ZZZ.Views.LibraryWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Style="{StaticResource AppWindowStyle}"
        Title="{DynamicResource Library}" Height="620" Width="840" MinHeight="460" MinWidth="650" WindowStartupLocation="CenterOwner">
    <Border Background="{DynamicResource WindowBrush}" Padding="14">
        <TabControl Background="{DynamicResource WindowBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource LineBrush}">
            <TabItem Header="{DynamicResource Bookmarks}">
                <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="220"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{DynamicResource BookmarkGroup}" VerticalAlignment="Center" Margin="0,0,8,0"/><ComboBox x:Name="BookmarkGroupFilterBox" Grid.Column="1" SelectionChanged="BookmarkGroupFilterBox_SelectionChanged"/><TextBlock Grid.Column="2" Text="{DynamicResource Search}" VerticalAlignment="Center" Margin="12,0,8,0"/><TextBox x:Name="BookmarkSearchBox" Grid.Column="3" Padding="10,6" ToolTip="{DynamicResource SearchBookmarks}" TextChanged="BookmarkSearchBox_TextChanged"/></Grid>
                    <DataGrid x:Name="BookmarksGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="False" SelectionMode="Single" CanUserAddRows="False" MouseDoubleClick="BookmarksGrid_MouseDoubleClick" RowHeight="54" HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="48" IsReadOnly="True"><DataGridTemplateColumn.CellTemplate><DataTemplate><Grid Width="28" Height="28"><Border CornerRadius="8" Background="{DynamicResource AccentSoftBrush}"/><TextBlock Text="{Binding FaviconFallback}" Foreground="{DynamicResource AccentTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/><Image Source="{Binding Favicon}" Width="24" Height="24" Stretch="Uniform"/></Grid></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="{DynamicResource ShowOnStart}" Binding="{Binding ShowOnStartPage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="82"/>
                            <DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridTextColumn Header="{DynamicResource BookmarkGroup}" Binding="{Binding Group, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                            <DataGridTextColumn Header="{DynamicResource Address}" Binding="{Binding Url}" IsReadOnly="True" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0"><Button Content="{DynamicResource Open}" Click="OpenBookmark_Click"/><Button Content="{DynamicResource Remove}" Click="RemoveBookmark_Click"/><Button Content="{DynamicResource Save}" Click="SaveBookmarks_Click" Style="{StaticResource PrimaryButton}"/><Button Content="{DynamicResource ImportHtml}" Click="ImportBookmarks_Click"/><Button Content="{DynamicResource ExportHtml}" Click="ExportBookmarks_Click"/></StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource History}">
                <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10"><TextBlock Text="{DynamicResource Search}" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox x:Name="HistorySearchBox" Padding="10,6" ToolTip="{DynamicResource SearchHistory}" TextChanged="HistorySearchBox_TextChanged"/></DockPanel>
                    <DataGrid x:Name="HistoryGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="HistoryGrid_MouseDoubleClick" RowHeight="58" HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate><Grid Width="30" Height="30"><Border CornerRadius="8" Background="{DynamicResource AccentSoftBrush}"/><TextBlock Text="{Binding FaviconFallback}" Foreground="{DynamicResource AccentTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/><Image Source="{Binding Favicon}" Width="26" Height="26" Stretch="Uniform"/></Grid></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{DynamicResource Page}" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel VerticalAlignment="Center"><TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Url}" Foreground="{DynamicResource MutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource Visited}" Binding="{Binding VisitedUtc, StringFormat=g}" Width="165"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0"><Button Content="{DynamicResource Open}" Click="OpenHistory_Click"/><Button Content="{DynamicResource RemoveSelectedHistory}" Click="RemoveHistory_Click"/><Button Content="{DynamicResource ClearHistory}" Click="ClearHistory_Click"/></StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource Userscripts}">
                <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <DataGrid x:Name="ScriptsGrid" Grid.Column="0" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="ScriptsGrid_SelectionChanged" CanUserAddRows="False">
                        <DataGrid.Columns><DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="45"/><DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding Name}" Width="*"/></DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Column="1" Margin="12,0,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBox Text="{Binding ElementName=ScriptsGrid, Path=SelectedItem.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="Script name"/>
                        <TextBox Grid.Row="1" Text="{Binding ElementName=ScriptsGrid, Path=SelectedItem.Match, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="URL match, for example https://example.com/*"/>
                        <TextBox Grid.Row="2" Text="{Binding ElementName=ScriptsGrid, Path=SelectedItem.Code, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas" TextWrapping="NoWrap"/>
                    </Grid>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,10,0,0"><Button Content="{DynamicResource NewScript}" Click="NewScript_Click"/><Button Content="{DynamicResource ImportUserScript}" Click="ImportScript_Click"/><Button Content="{DynamicResource Remove}" Click="RemoveScript_Click"/><Button Content="{DynamicResource SaveScripts}" Click="SaveScripts_Click" Style="{StaticResource PrimaryButton}"/></StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Border>
</Window>
