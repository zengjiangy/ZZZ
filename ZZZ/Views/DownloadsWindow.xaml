<Window x:Class="ZZZ.Views.DownloadsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Downloads}" Height="430" Width="740" MinHeight="320" MinWidth="560" WindowStartupLocation="CenterOwner">
    <Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="{DynamicResource Downloads}" FontSize="21" FontWeight="SemiBold" Margin="5,2,0,12"/>
        <DataGrid Grid.Row="1" x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns><DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding FileName}" Width="2*"/><DataGridTextColumn Header="{DynamicResource Status}" Binding="{Binding Status}" Width="90"/><DataGridTextColumn Header="{DynamicResource SavedTo}" Binding="{Binding ResultPath}" Width="3*"/></DataGrid.Columns>
        </DataGrid>
        <Button Grid.Row="2" Content="{DynamicResource OpenFolder}" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OpenFolder_Click"/>
    </Grid>
</Window>
