<Window x:Class="ZZZ.Views.TermsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}"
        Title="{DynamicResource TermsTitle}" Height="590" Width="680" MinHeight="500" MinWidth="580"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <Grid Background="{DynamicResource WindowBrush}">
        <Grid.RowDefinitions><RowDefinition Height="72"/><RowDefinition Height="*"/><RowDefinition Height="72"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="22,0" VerticalAlignment="Center">
                <Border Width="38" Height="38" Background="{DynamicResource AppIconBrush}" CornerRadius="11" Margin="0,0,12,0"><Viewbox Margin="8"><Path Stroke="White" StrokeThickness="2.6" Data="M2,4 L16,4 L4,16 L18,16 M9,10 L18,10 L11,17"/></Viewbox></Border>
                <StackPanel VerticalAlignment="Center"><TextBlock Text="{DynamicResource TermsTitle}" FontSize="21" FontWeight="SemiBold"/><TextBlock Text="ZZZ 2.0" Foreground="{DynamicResource MutedBrush}"/></StackPanel>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
            <StackPanel MaxWidth="600">
                <TextBlock Text="{DynamicResource TermsIntro}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,16"/>
                <TextBlock Text="{DynamicResource TermsUseHeading}" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="{DynamicResource TermsUseBody}" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,15"/>
                <TextBlock Text="{DynamicResource TermsPrivacyHeading}" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="{DynamicResource TermsPrivacyBody}" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,15"/>
                <TextBlock Text="{DynamicResource TermsThirdPartyHeading}" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="{DynamicResource TermsThirdPartyBody}" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,15"/>
                <TextBlock Text="{DynamicResource TermsDisclaimerHeading}" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="{DynamicResource TermsDisclaimerBody}" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,15"/>
                <Border Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="13"><TextBlock Text="{DynamicResource TermsAcceptance}" TextWrapping="Wrap"/></Border>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0">
                <Button Content="{DynamicResource ExitApplication}" Click="Decline_Click" IsCancel="True" Margin="0,0,8,0"/>
                <Button Content="{DynamicResource AgreeAndContinue}" Click="Accept_Click" IsDefault="True" Style="{StaticResource PrimaryButton}" MinWidth="150"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
