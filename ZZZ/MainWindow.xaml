<Window x:Class="ZZZ.MainWindow" x:Name="RootWindow" Style="{StaticResource AppWindowStyle}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppName}" Height="820" Width="1280" MinHeight="500" MinWidth="780"
        WindowStartupLocation="CenterScreen" KeyDown="Window_KeyDown" Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="HorizontalTabItemContainer" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Margin" Value="3,5,1,4"/><Setter Property="Padding" Value="0"/><Setter Property="Focusable" Value="False"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="TabBorder" Width="192" Height="39" Background="{TemplateBinding Background}" CornerRadius="11" BorderBrush="Transparent" BorderThickness="1">
                    <Grid><ContentPresenter/><Border x:Name="Indicator" Height="2" VerticalAlignment="Bottom" Margin="18,0,18,2" Background="Transparent" CornerRadius="2"/></Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBrush}"/></Trigger>
                    <Trigger Property="IsSelected" Value="True"><Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource LineBrush}"/><Setter TargetName="Indicator" Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Panel.ZIndex" Value="2"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="VerticalTabItemContainer" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Margin" Value="6,2"/><Setter Property="Padding" Value="0"/><Setter Property="Focusable" Value="False"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="TabBorder" Height="44" Background="{TemplateBinding Background}" CornerRadius="11" BorderBrush="Transparent" BorderThickness="1">
                    <Grid><ContentPresenter/><Border x:Name="Indicator" Width="3" HorizontalAlignment="Left" Margin="0,9" Background="Transparent" CornerRadius="2"/></Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBrush}"/></Trigger>
                    <Trigger Property="IsSelected" Value="True"><Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceBrush}"/><Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource LineBrush}"/><Setter TargetName="Indicator" Property="Background" Value="{DynamicResource AccentBrush}"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <DataTemplate x:Key="HorizontalTabTemplate">
            <Grid Margin="7,0,2,0" ContextMenuOpening="TabContextMenu_Opening"><Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                <Grid x:Name="FaviconHost" Width="18" Height="18" VerticalAlignment="Center"><Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="5"/><TextBlock Text="{Binding FaviconFallback}" Foreground="{DynamicResource AccentTextBrush}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/><Image Source="{Binding Favicon}" Width="18" Height="18" Stretch="Uniform"/></Grid>
                <Path x:Name="PrivateTabIcon" Grid.Column="0" Visibility="Collapsed" Fill="{DynamicResource AccentBrush}" Margin="2" Data="M6,0.8 L11,2.7 L10.5,7.5 C10.2,9.7 8.4,11.5 6,12.4 C3.6,11.5 1.8,9.7 1.5,7.5 L1,2.7 Z M4.3,6 L7.7,6 L7.7,9 L4.3,9 Z M5,6 L5,4.9 C5,3.6 7,3.6 7,4.9 L7,6 Z" Stretch="Uniform"/>
                <Button Grid.Column="1" Padding="6,0" HorizontalContentAlignment="Left" Command="{Binding DataContext.SelectTabCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}" ToolTip="{Binding Url}"><TextBlock Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/></Button>
                <Button Grid.Column="2" Content="×" FontSize="16" Padding="0" Width="25" Height="25" Command="{Binding DataContext.CloseTabCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}" ToolTip="{DynamicResource CloseTab}"/>
                <Grid.ContextMenu><ContextMenu>
                    <MenuItem Header="{DynamicResource DuplicateTab}" Command="{Binding DataContext.DuplicateTabCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                    <MenuItem Header="{DynamicResource CloseTab}" Command="{Binding DataContext.CloseTabCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                    <Separator/><MenuItem Header="{DynamicResource CloseOthers}" Command="{Binding DataContext.CloseOthersCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                    <MenuItem Header="{DynamicResource CloseRight}" Command="{Binding DataContext.CloseTabsToRightCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                </ContextMenu></Grid.ContextMenu>
            </Grid>
            <DataTemplate.Triggers><DataTrigger Binding="{Binding IsPrivate}" Value="True"><Setter TargetName="FaviconHost" Property="Visibility" Value="Collapsed"/><Setter TargetName="PrivateTabIcon" Property="Visibility" Value="Visible"/></DataTrigger></DataTemplate.Triggers>
        </DataTemplate>
        <DataTemplate x:Key="VerticalTabTemplate">
            <Grid Margin="10,0,3,0" ContextMenuOpening="TabContextMenu_Opening"><Grid.ColumnDefinitions><ColumnDefinition Width="22"/><ColumnDefinition Width="*"/><ColumnDefinition Width="29"/></Grid.ColumnDefinitions>
                <Grid x:Name="VerticalFaviconHost" Width="20" Height="20" VerticalAlignment="Center"><Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="6"/><TextBlock Text="{Binding FaviconFallback}" Foreground="{DynamicResource AccentTextBrush}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/><Image Source="{Binding Favicon}" Width="20" Height="20" Stretch="Uniform"/></Grid>
                <Path x:Name="VerticalPrivateTabIcon" Grid.Column="0" Visibility="Collapsed" Fill="{DynamicResource AccentBrush}" Margin="2" Data="M6,0.8 L11,2.7 L10.5,7.5 C10.2,9.7 8.4,11.5 6,12.4 C3.6,11.5 1.8,9.7 1.5,7.5 L1,2.7 Z M4.3,6 L7.7,6 L7.7,9 L4.3,9 Z M5,6 L5,4.9 C5,3.6 7,3.6 7,4.9 L7,6 Z" Stretch="Uniform"/>
                <Button x:Name="VerticalTitleButton" Grid.Column="1" Padding="7,0" HorizontalContentAlignment="Left" Command="{Binding DataContext.SelectTabCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}" ToolTip="{Binding Url}"><TextBlock Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/></Button>
                <Button x:Name="VerticalCloseButton" Grid.Column="2" Content="×" FontSize="16" Padding="0" Width="25" Height="25" Command="{Binding DataContext.CloseTabCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}" ToolTip="{DynamicResource CloseTab}"/>
                <Grid.ContextMenu><ContextMenu>
                    <MenuItem Header="{DynamicResource DuplicateTab}" Command="{Binding DataContext.DuplicateTabCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                    <MenuItem Header="{DynamicResource CloseTab}" Command="{Binding DataContext.CloseTabCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                    <Separator/><MenuItem Header="{DynamicResource CloseOthers}" Command="{Binding DataContext.CloseOthersCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                    <MenuItem Header="{DynamicResource CloseRight}" Command="{Binding DataContext.CloseTabsToRightCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                </ContextMenu></Grid.ContextMenu>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsPrivate}" Value="True"><Setter TargetName="VerticalFaviconHost" Property="Visibility" Value="Collapsed"/><Setter TargetName="VerticalPrivateTabIcon" Property="Visibility" Value="Visible"/></DataTrigger>
                <DataTrigger Binding="{Binding DataContext.AreVerticalTabsExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"><Setter TargetName="VerticalTitleButton" Property="Visibility" Value="Collapsed"/><Setter TargetName="VerticalCloseButton" Property="Visibility" Value="Collapsed"/></DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>
    <Grid Background="{DynamicResource WindowBrush}">
        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border x:Name="VerticalTabBar" Grid.Column="0" Width="{Binding VerticalTabBarWidth}" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0" Visibility="{Binding ShowVerticalTabBar, Converter={StaticResource BoolVisibility}}">
            <Grid><Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="48"/></Grid.RowDefinitions>
                <Grid Margin="7,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                    <Button Click="WorkspaceButton_Click" ToolTip="{Binding ActiveWorkspace.Name}" HorizontalContentAlignment="Left" Padding="8,4"><StackPanel Orientation="Horizontal"><Ellipse Width="18" Height="18" Fill="{Binding ActiveWorkspace.Color}"/><TextBlock Text="{Binding ActiveWorkspace.Name}" Visibility="{Binding AreVerticalTabsExpanded, Converter={StaticResource BoolVisibility}}" FontWeight="SemiBold" Margin="9,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/></StackPanel></Button>
                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Command="{Binding ToggleVerticalTabsCollapsedCommand}" ToolTip="{DynamicResource CollapseVerticalTabs}"><TextBlock Text="⇆" FontSize="17"/></Button>
                </Grid>
                <Button Grid.Row="1" Margin="7,4" HorizontalContentAlignment="Left" Command="{Binding CreateTabCommand}" ToolTip="{DynamicResource NewTab}" Padding="11,6"><StackPanel Orientation="Horizontal"><Path Width="17" Height="17" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Data="M9,2 L9,16 M2,9 L16,9" Stretch="Uniform"/><TextBlock Text="{DynamicResource NewTab}" Visibility="{Binding AreVerticalTabsExpanded, Converter={StaticResource BoolVisibility}}" Margin="10,0,0,0" VerticalAlignment="Center"/></StackPanel></Button>
                <ListBox x:Name="VerticalTabsList" Grid.Row="2" ItemsSource="{Binding WorkspaceTabs}" SelectedItem="{Binding SelectedTab, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ItemContainerStyle="{StaticResource VerticalTabItemContainer}" ItemTemplate="{StaticResource VerticalTabTemplate}" SelectionChanged="TabsList_SelectionChanged"
                         AllowDrop="True" PreviewMouseLeftButtonDown="TabsList_PreviewMouseLeftButtonDown" PreviewMouseMove="TabsList_PreviewMouseMove" DragOver="TabsList_DragOver" Drop="TabsList_Drop" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                <Button Grid.Row="3" Margin="7,4" HorizontalContentAlignment="Left" Click="WorkspaceButton_Click" ToolTip="{DynamicResource Workspaces}" Padding="11,6"><StackPanel Orientation="Horizontal"><TextBlock Text="◈" FontSize="17"/><TextBlock Text="{DynamicResource ManageWorkspaces}" Visibility="{Binding AreVerticalTabsExpanded, Converter={StaticResource BoolVisibility}}" Margin="10,0,0,0" VerticalAlignment="Center"/></StackPanel></Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="2"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Border x:Name="TabBar" Grid.Row="0" Height="49" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Visibility="{Binding ShowHorizontalTabBar, Converter={StaticResource BoolVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <Button Width="36" Height="36" Click="WorkspaceButton_Click" ToolTip="{Binding ActiveWorkspace.Name}" Padding="7"><Grid><Ellipse Fill="{Binding ActiveWorkspace.Color}"/><TextBlock Text="◈" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/></Grid></Button>
                <ListBox x:Name="HorizontalTabsList" Grid.Column="1" ItemsSource="{Binding WorkspaceTabs}" SelectedItem="{Binding SelectedTab, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ItemContainerStyle="{StaticResource HorizontalTabItemContainer}" ItemTemplate="{StaticResource HorizontalTabTemplate}" SelectionChanged="TabsList_SelectionChanged"
                         AllowDrop="True" PreviewMouseLeftButtonDown="TabsList_PreviewMouseLeftButtonDown" PreviewMouseMove="TabsList_PreviewMouseMove" DragOver="TabsList_DragOver" Drop="TabsList_Drop"
                         Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel><ItemsPanelTemplate><VirtualizingStackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ListBox.ItemsPanel>
                </ListBox>
                <Button Grid.Column="2" Style="{StaticResource IconButton}" ToolTip="{DynamicResource NewTab}" Command="{Binding CreateTabCommand}">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Data="M9,2 L9,16 M2,9 L16,9" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="Toolbar" Grid.Row="1" Margin="10,8,10,9" Padding="6" Background="{DynamicResource ToolbarBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="15"
                Visibility="{Binding Services.Settings.Current.Ui.ShowToolbar, Converter={StaticResource BoolVisibility}}">
            <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.11" Color="#382A2450"/></Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Back}" Command="{Binding SelectedTab.BackCommand}" IsEnabled="{Binding SelectedTab.CanGoBack}"><Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M14,3 L6,10 L14,17" Stretch="Uniform"/></Button>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Forward}" Command="{Binding SelectedTab.ForwardCommand}" IsEnabled="{Binding SelectedTab.CanGoForward}"><Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M6,3 L14,10 L6,17" Stretch="Uniform"/></Button>
                <Button Grid.Column="2" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Reload}" Command="{Binding SelectedTab.ReloadCommand}">
                    <Viewbox Width="18" Height="18"><Canvas Width="20" Height="20">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M16.4,7.4 A7,7 0 1 0 16.1,14.1"/>
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M16.4,3.2 L16.4,7.4 L12.2,7.4"/>
                    </Canvas></Viewbox>
                </Button>
                <Button Grid.Column="3" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Home}" Command="{Binding SelectedTab.HomeCommand}"><Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeLineJoin="Round" Data="M2,9 L9,3 L16,9 M4,8 L4,16 L14,16 L14,8 M8,16 L8,11 L11,11 L11,16" Stretch="Uniform"/></Button>
                <Grid x:Name="AddressHost" Grid.Column="4" Margin="5,0" Visibility="{Binding Services.Settings.Current.Ui.ShowAddressBar, Converter={StaticResource BoolVisibility}}">
                    <TextBox x:Name="AddressBox" Height="40" Text="{Binding SelectedTab.Address, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" FontSize="14" PreviewKeyDown="AddressBox_KeyDown" TextChanged="AddressBox_TextChanged" GotKeyboardFocus="AddressBox_GotKeyboardFocus" ToolTip="{DynamicResource AddressPlaceholder}" Padding="16,8,92,8"/>
                    <Popup x:Name="AddressSuggestionsPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=AddressBox}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="5">
                        <Border Width="{Binding ActualWidth, ElementName=AddressBox}" MaxHeight="360" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="13" Padding="5">
                            <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.25"/></Border.Effect>
                            <ListBox x:Name="AddressSuggestionsList" Background="Transparent" BorderThickness="0" PreviewMouseLeftButtonUp="AddressSuggestionsList_MouseUp" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Padding" Value="10,7"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextBrush}"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource HoverBrush}"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/></Trigger></Style.Triggers></Style></ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate><DataTemplate><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource MutedBrush}" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding Kind}" Foreground="{DynamicResource MutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="12,0,2,0"/></Grid></DataTemplate></ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,9,0" Padding="9,4" Background="{DynamicResource AccentSoftBrush}" CornerRadius="9" IsHitTestVisible="False">
                        <TextBlock x:Name="SiteIdentityBadge" Text="{Binding SelectedTab.SiteIdentity}" Foreground="{DynamicResource AccentTextBrush}" FontSize="10" FontWeight="SemiBold" TextOptions.TextFormattingMode="Ideal"/>
                    </Border>
                </Grid>
                <Button Grid.Column="5" Style="{StaticResource IconButton}" ToolTip="{DynamicResource ReadingMode}" Command="{Binding SelectedTab.ToggleReaderModeCommand}"><TextBlock Text="阅" FontSize="15" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextBrush}"/><Style.Triggers><DataTrigger Binding="{Binding SelectedTab.IsReaderMode}" Value="True"><Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></Button>
                <Button Grid.Column="6" Style="{StaticResource IconButton}" ToolTip="{DynamicResource TranslatePage}" Command="{Binding SelectedTab.TranslateCommand}"><TextBlock Text="译" FontSize="15" FontWeight="SemiBold"/></Button>
                <Button x:Name="BookmarkButton" Grid.Column="7" Style="{StaticResource IconButton}" ToolTip="{DynamicResource BookmarkPage}" Command="{Binding AddBookmarkCommand}">
                    <Path StrokeThickness="1.6" StrokeLineJoin="Round" Data="M9,2 L11.2,6.5 L16,7.2 L12.5,10.6 L13.3,15.5 L9,13.2 L4.7,15.5 L5.5,10.6 L2,7.2 L6.8,6.5 Z" Stretch="Uniform">
                        <Path.Style><Style TargetType="Path"><Setter Property="Stroke" Value="{DynamicResource TextBrush}"/><Setter Property="Fill" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsCurrentPageBookmarked}" Value="True"><Setter Property="Stroke" Value="{DynamicResource AccentTextBrush}"/><Setter Property="Fill" Value="{DynamicResource AccentBrush}"/></DataTrigger></Style.Triggers></Style></Path.Style>
                    </Path>
                </Button>
                <Button x:Name="MediaButton" Grid.Column="8" Style="{StaticResource IconButton}" ToolTip="{DynamicResource DetectedMedia}" Click="MediaButton_Click"><Path Fill="{DynamicResource AccentBrush}" Data="M6,2 L15,2 L15,12 C15,14 13.5,16 11,16 C9,16 8,15 8,13.5 C8,12 9.5,11 11.5,11 C12.2,11 12.8,11.1 13.2,11.4 L13.2,5 L7.8,5 L7.8,13 C7.8,15 6,17 3.8,17 C1.8,17 .8,15.8 .8,14.4 C.8,12.8 2.3,11.8 4.2,11.8 C4.9,11.8 5.5,12 6,12.3 Z" Stretch="Uniform"/></Button>
                <Button x:Name="MenuButton" Grid.Column="9" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Menu}" Click="MenuButton_Click"><Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="M3,8 A2,2 0 1 0 3,12 A2,2 0 1 0 3,8 M10,8 A2,2 0 1 0 10,12 A2,2 0 1 0 10,8 M17,8 A2,2 0 1 0 17,12 A2,2 0 1 0 17,8" Stretch="Uniform"/></Button>
            </Grid>
        </Border>

        <ProgressBar Grid.Row="2" Height="2" IsIndeterminate="True" Foreground="{DynamicResource AccentBrush}" Background="Transparent" Visibility="{Binding SelectedTab.IsLoading, Converter={StaticResource BoolVisibility}}"/>
        <Border Grid.Row="3" Background="{DynamicResource WebBackdropBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <!-- WebView2 is an HWND surface, so tool strips live in their own layout row instead of overlaying the page. -->
                <WrapPanel x:Name="PageTools" Background="{DynamicResource SurfaceAltBrush}" HorizontalAlignment="Right">
                    <Border Margin="8,5" Padding="10,5" CornerRadius="9" Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Visibility="{Binding ShowSessionRestorePrompt, Converter={StaticResource BoolVisibility}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource RestoreSessionPrompt}" VerticalAlignment="Center" Margin="2,0,10,0"/>
                            <Button Content="{DynamicResource Restore}" Command="{Binding RestorePreviousSessionCommand}" Style="{StaticResource PrimaryButton}" Padding="12,5"/>
                            <Button Content="{DynamicResource NotNow}" Command="{Binding DismissPreviousSessionCommand}" Padding="10,5" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="SplitBar" Margin="8,5" Padding="7,3" CornerRadius="9" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SplitScreen}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="5,0,9,0"/>
                            <Button x:Name="SplitOrientationButton" Content="↕" Click="ToggleSplitOrientation_Click" ToolTip="{DynamicResource ToggleSplitOrientation}"/>
                            <Border Width="1" Height="22" Background="{DynamicResource LineBrush}" Margin="5,0"/>
                            <TextBlock Text="{DynamicResource PrimaryPane}" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/><Button Content="−" Click="PrimaryZoomOut_Click"/><Button Content="100%" Click="PrimaryZoomReset_Click"/><Button Content="+" Click="PrimaryZoomIn_Click"/>
                            <TextBlock Text="{DynamicResource SecondaryPane}" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" Margin="8,0,0,0"/><Button Content="−" Click="SecondaryZoomOut_Click"/><Button Content="100%" Click="SecondaryZoomReset_Click"/><Button Content="+" Click="SecondaryZoomIn_Click"/>
                            <Button Content="×" Click="CloseSplit_Click" ToolTip="{DynamicResource CloseSplit}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="FindBar" Margin="8,5" Padding="7,3" CornerRadius="9" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal"><TextBox x:Name="FindBox" Width="230" Padding="10,6" KeyDown="FindBox_KeyDown"/><Button Content="↑" Click="FindPrevious_Click" ToolTip="{DynamicResource FindPrevious}"/><Button Content="↓" Click="FindNext_Click" ToolTip="{DynamicResource FindNext}"/><Button Content="×" Click="CloseFind_Click" ToolTip="{DynamicResource Close}"/></StackPanel>
                    </Border>
                </WrapPanel>
                <Grid x:Name="BrowserArea" Grid.Row="1" ClipToBounds="True"><Grid.ColumnDefinitions><ColumnDefinition x:Name="PrimaryColumn" Width="*"/><ColumnDefinition x:Name="SplitterColumn" Width="0"/><ColumnDefinition x:Name="SecondaryColumn" Width="0"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition x:Name="PrimaryRow" Height="*"/><RowDefinition x:Name="HorizontalSplitterRow" Height="0"/><RowDefinition x:Name="SecondaryRow" Height="0"/></Grid.RowDefinitions>
                    <ContentControl x:Name="TabContentHost" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                    <GridSplitter x:Name="SplitDivider" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{DynamicResource LineBrush}" Visibility="Collapsed"/>
                    <GridSplitter x:Name="HorizontalSplitDivider" Grid.Row="1" Height="5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{DynamicResource LineBrush}" Visibility="Collapsed"/>
                    <ContentControl x:Name="SecondaryTabContentHost" Grid.Column="2" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                </Grid>
            </Grid>
        </Border>
        <Border x:Name="StatusBar" Grid.Row="4" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"><TextBlock Text="{Binding SelectedTab.Status}" Foreground="{DynamicResource MutedBrush}" Margin="14,5" FontSize="11" TextTrimming="CharacterEllipsis"/></Border>
        </Grid>

        <Popup x:Name="WorkspacePopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="5">
            <Border Width="360" MaxHeight="520" Padding="14" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="13">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.28"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Workspaces}" FontSize="17" FontWeight="SemiBold" Margin="2,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Workspaces}"><ItemsControl.ItemTemplate><DataTemplate>
                        <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Button HorizontalContentAlignment="Stretch" Command="{Binding DataContext.SwitchWorkspaceCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}" Padding="9,7"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Ellipse Width="16" Height="16" Fill="{Binding Color}"/><TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/></Grid></Button>
                            <Button Grid.Column="1" Content="→" ToolTip="{DynamicResource MoveTabToWorkspace}" Command="{Binding DataContext.MoveSelectedTabToWorkspaceCommand, Source={x:Reference RootWindow}}" CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    <Separator Margin="0,9"/>
                    <TextBlock Text="{DynamicResource RenameWorkspace}" FontWeight="SemiBold" Margin="2,0,0,4"/>
                    <DockPanel><Button DockPanel.Dock="Right" Content="{DynamicResource Save}" Command="{Binding SaveWorkspaceCommand}" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0"/><TextBox Text="{Binding ActiveWorkspace.Name, UpdateSourceTrigger=PropertyChanged}" Padding="9,6"/></DockPanel>
                    <TextBlock Text="{DynamicResource NewWorkspace}" FontWeight="SemiBold" Margin="2,12,0,4"/>
                    <DockPanel><Button DockPanel.Dock="Right" Content="{DynamicResource Add}" Click="AddWorkspace_Click" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0"/><TextBox x:Name="NewWorkspaceNameBox" Padding="9,6" ToolTip="{DynamicResource WorkspaceName}"/></DockPanel>
                    <Button Content="{DynamicResource DeleteWorkspace}" Command="{Binding DeleteWorkspaceCommand}" IsEnabled="{Binding CanDeleteWorkspace}" Foreground="#D64F70" HorizontalAlignment="Left" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
